# ─────────────────────────────────────────────────────────────
# Bitcoin Market Score — Environment Variables
# Copy this file to `.env.local` and fill in the values you have.
# The app runs without any keys: free/public sources (Binance,
# Fear & Greed, CoinGecko) work live; keyed sources fall back to
# neutral baselines flagged as "stale" until you add a key.
# ─────────────────────────────────────────────────────────────

# Binance API (public endpoints — no key required)
# Spot uses the geo-unrestricted public data mirror so it works from US cloud
# IPs (Vercel). Leave these unset to use the defaults baked into the app.
NEXT_PUBLIC_BINANCE_BASE_URL=https://data-api.binance.vision
NEXT_PUBLIC_BINANCE_FUTURES_BASE_URL=https://fapi.binance.com

# Alternative.me Fear & Greed (no key required)
NEXT_PUBLIC_FEAR_GREED_URL=https://api.alternative.me/fng/

# CoinGecko (free tier — no key required)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Macro data (DXY, NASDAQ, S&P 500, WTI) now uses Stooq and CPI uses the BLS
# public API — both KEYLESS. The keys below are OPTIONAL fallbacks only.

# FRED API (optional fallback for CPI — register at https://fred.stlouisfed.org)
FRED_API_KEY=

# Alpha Vantage (no longer used; kept for reference)
ALPHA_VANTAGE_API_KEY=

# Vercel KV (auto-injected on Vercel, manual for local dev)
KV_URL=your_kv_url
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token

# Secret used to authorize the daily cron job (Authorization: Bearer <secret>)
CRON_SECRET=your_cron_secret_here
